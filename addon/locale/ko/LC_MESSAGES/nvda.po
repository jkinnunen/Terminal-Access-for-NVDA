#: addon/globalPlugins/terminalAccess.py:121
msgid "Terminal Access"
msgstr "터미널 접속"

#: addon/globalPlugins/terminalAccess.py:2326
#, python-brace-format
msgid "Selection too large: {rows} rows exceeds maximum of {max}"
msgstr "선택된 행 수가 너무 많습니다: {rows} 행이 최대 허용 행 수 {max}를 초과합니다."

#: addon/globalPlugins/terminalAccess.py:2331
#, python-brace-format
msgid "Selection too wide: {cols} columns exceeds maximum of {max}"
msgstr "선택 범위가 너무 넓습니다: {cols} 열이 최대 허용값 {max}을 초과합니다."

#: addon/globalPlugins/terminalAccess.py:3050
msgid "Initializing..."
msgstr "초기화 중..."

# Summary when many new lines arrive at once
#: addon/globalPlugins/terminalAccess.py:3377
#, python-brace-format
msgid "{n} new lines"
msgstr "{n} 새 줄"

# Title for URL list dialog
#: addon/globalPlugins/terminalAccess.py:4936
msgid "URL List - Terminal Access"
msgstr "URL 목록 - 터미널 접속"

# Label for URL filter text box
#: addon/globalPlugins/terminalAccess.py:4948
msgid "&Filter:"
msgstr "&필터:"

# Column header for URL list index
#: addon/globalPlugins/terminalAccess.py:4958
msgid "#"
msgstr "#"

# Column header for URL
#: addon/globalPlugins/terminalAccess.py:4960
msgid "URL"
msgstr "URL"

# Column header for line number
#: addon/globalPlugins/terminalAccess.py:4962
msgid "Line"
msgstr "라인"

# Column header for line context
#: addon/globalPlugins/terminalAccess.py:4964
msgid "Context"
msgstr "문맥"

# Button to open URL in browser
#: addon/globalPlugins/terminalAccess.py:4971
msgid "&Open"
msgstr "&열기"

# Button to copy URL to clipboard
#: addon/globalPlugins/terminalAccess.py:4973
msgid "&Copy URL"
msgstr "&Copy URL"

# Button to move cursor to URL line
#: addon/globalPlugins/terminalAccess.py:4975
msgid "&Move to line"
msgstr "&줄로 이동"

#: addon/globalPlugins/terminalAccess.py:4977
msgid "Close"
msgstr "닫기"

# Announced after URL is copied
#: addon/globalPlugins/terminalAccess.py:5058
msgid "URL copied"
msgstr "URL 복사됨"

# Announced when moving to a URL line
#: addon/globalPlugins/terminalAccess.py:5069
#, python-brace-format
msgid "Line {num}: {text}"
msgstr "{num} 라인: {text}"

# Position context for verbose mode
#: addon/globalPlugins/terminalAccess.py:5443
#, python-brace-format
msgid "Row {row}, column {col}"
msgstr "{row}행, {col}열"

# Format for verbose announcements with context
#: addon/globalPlugins/terminalAccess.py:5481
#, python-brace-format
msgid "{message}. {context}"
msgstr "{message}. {context}"

# Message announced when entering a terminal application
#: addon/globalPlugins/terminalAccess.py:5587
msgid "Terminal Access support active. Press NVDA+shift+f1 for help."
msgstr "터미널 액세스 지원 활성화됨. 도움말은 NVDA+Shift+F1을 누르세요."

# Message format for repeated symbols, e.g. "3 dash"
#: addon/globalPlugins/terminalAccess.py:5717
#, python-brace-format
msgid "{count} {symbol}"
msgstr "{count} {symbol}"

#: addon/globalPlugins/terminalAccess.py:5930
#, python-brace-format
msgid "Highlighted: {text}"
msgstr "하이라이트: {text}"

# Description for the show help gesture
#: addon/globalPlugins/terminalAccess.py:6018
msgid "Opens the Terminal Access user guide"
msgstr "터미널 액세스 사용자 가이드 열기"

# Error message when help file is not found
#: addon/globalPlugins/terminalAccess.py:6033
msgid "Help file not found. Please reinstall the add-on."
msgstr "도움말 파일을 찾을 수 없습니다. 애드온을 다시 설치하십시오."

# Error message when add-on is not properly installed
#: addon/globalPlugins/terminalAccess.py:6036
msgid "Terminal Access add-on not properly installed."
msgstr "터미널 액세스 애드온이 제대로 설치되지 않았습니다."

# Description for reading the previous line
#: addon/globalPlugins/terminalAccess.py:6040
msgid "Read previous line in terminal"
msgstr "터미널에서 이전 줄 읽기"

# Description for reading the current line
#: addon/globalPlugins/terminalAccess.py:6054
msgid "Read current line in terminal. Press twice for indentation level."
msgstr "터미널에서 현재 줄 읽기. 들여쓰기 수준을 위해 두 번 누르세요."

# Description for reading the next line
#: addon/globalPlugins/terminalAccess.py:6073
msgid "Read next line in terminal"
msgstr "터미널에서 다음 줄 읽기"

# Description for reading the previous word
#: addon/globalPlugins/terminalAccess.py:6087
msgid "Read previous word in terminal"
msgstr "터미널에서 이전 단어 읽기"

# Description for reading the current word
#: addon/globalPlugins/terminalAccess.py:6101
msgid "Read current word in terminal"
msgstr "터미널에서 현재 단어 읽기"

# Description for spelling the current word
#: addon/globalPlugins/terminalAccess.py:6115
msgid "Spell current word in terminal"
msgstr "터미널에서 현재 단어 철자 맞추기"

# Description for reading the next word
#: addon/globalPlugins/terminalAccess.py:6129
msgid "Read next word in terminal"
msgstr "터미널에서 다음 단어 읽기"

# Description for reading the previous character
#: addon/globalPlugins/terminalAccess.py:6143
msgid "Read previous character in terminal"
msgstr "터미널에서 이전 문자 읽기"

# Description for reading the current character
#: addon/globalPlugins/terminalAccess.py:6157
msgid ""
"Read current character in terminal. Press twice for phonetic. Press three "
"times for character code."
msgstr "터미널에서 현재 문자를 읽습니다. 발음을 위해 두 번 누르세요. 문자 코드를 위해 세 번 누르세요."

# Description for reading the next character
#: addon/globalPlugins/terminalAccess.py:6181
msgid "Read next character in terminal"
msgstr "터미널에서 다음 문자를 읽으십시오"

# Description for toggling quiet mode
#: addon/globalPlugins/terminalAccess.py:6195
msgid "Toggle quiet mode in terminal"
msgstr "터미널에서 조용한 모드 전환"

# Message when quiet mode is enabled
#: addon/globalPlugins/terminalAccess.py:6215
msgid "Quiet mode on"
msgstr "조용한 모드 켜기"

# Message when quiet mode is disabled
#: addon/globalPlugins/terminalAccess.py:6218
msgid "Quiet mode off"
msgstr "무음 모드 해제"

# Description for toggling announce new output
#: addon/globalPlugins/terminalAccess.py:6222
msgid "Toggle announce new output in terminal"
msgstr "터미널에서 새 출력 알림 토글"

# Message when announce new output is enabled
#: addon/globalPlugins/terminalAccess.py:6246
msgid "Announce new output on"
msgstr "새로운 출력 발표"

# Message when announce new output is disabled
#: addon/globalPlugins/terminalAccess.py:6251
msgid "Announce new output off"
msgstr "새로운 출력 발표"

# Description for toggling indentation announcement
#: addon/globalPlugins/terminalAccess.py:6255
msgid "Toggle indentation announcement on line read in terminal"
msgstr "터미널에서 읽은 줄의 들여쓰기 표시 전환"

# Message when indentation announcement is enabled
#: addon/globalPlugins/terminalAccess.py:6273
msgid "Indentation announcement on"
msgstr "인덴테이션 공지사항"

# Message when indentation announcement is disabled
#: addon/globalPlugins/terminalAccess.py:6276
msgid "Indentation announcement off"
msgstr "들여쓰기 공지 해제"

# Description for copy mode
#: addon/globalPlugins/terminalAccess.py:6280
msgid "Enter copy mode in terminal"
msgstr "터미널에서 복사 모드로 진입"

# Message entering copy mode
#: addon/globalPlugins/terminalAccess.py:6297
msgid ""
"Copy mode. Press L to copy line, S to copy screen, or Escape to cancel."
msgstr "복사 모드. L 키를 눌러 줄 복사, S 키를 눌러 화면 복사, Esc 키를 눌러 취소합니다."

# Description for copying line
#: addon/globalPlugins/terminalAccess.py:6301
msgid "Copy line in copy mode"
msgstr "복사 모드에서 줄 복사"

#: addon/globalPlugins/terminalAccess.py:6313
msgid "Unable to copy"
msgstr "복사할 수 없습니다"

# Message when line is copied
#: addon/globalPlugins/terminalAccess.py:6321
msgid "Line copied"
msgstr "라인 복사됨"

# Description for copying screen
#: addon/globalPlugins/terminalAccess.py:6332
msgid "Copy screen in copy mode"
msgstr "복사 모드에서 화면 복사"

# Message when screen is copied
#: addon/globalPlugins/terminalAccess.py:6352
msgid "Screen copied"
msgstr "화면 복사됨"

# Description for exiting copy mode
#: addon/globalPlugins/terminalAccess.py:6363
msgid "Exit copy mode"
msgstr "복사 모드 종료"

# Message when copy mode is canceled
#: addon/globalPlugins/terminalAccess.py:6373
msgid "Copy mode canceled"
msgstr "복사 모드 취소됨"

# Description for toggling the command layer
#: addon/globalPlugins/terminalAccess.py:6401
msgid "Toggle terminal command layer (single-key command mode)"
msgstr "터미널 명령어 레이어 전환 (단일 키 명령어 모드)"

# Announced when the terminal command layer is activated
#: addon/globalPlugins/terminalAccess.py:6430
msgid "Terminal commands"
msgstr "터미널 명령어"

# Announced when the terminal command layer is deactivated
#: addon/globalPlugins/terminalAccess.py:6444
msgid "Exit terminal commands"
msgstr "터미널 명령어 종료"

# Description for exiting the command layer
#: addon/globalPlugins/terminalAccess.py:6448
msgid "Exit the terminal command layer"
msgstr "터미널 명령어 레이어에서 나가기"

# Description for opening terminal settings
#: addon/globalPlugins/terminalAccess.py:6460
msgid "Open Terminal Access settings"
msgstr "터미널 액세스 설정 열기"

# Error message when settings dialog cannot be opened
#: addon/globalPlugins/terminalAccess.py:6474
msgid "Unable to open settings dialog. Please try again."
msgstr "설정 대화 상자를 열 수 없습니다. 다시 시도해 주세요."

# Description for cycling cursor tracking modes
#: addon/globalPlugins/terminalAccess.py:6478
msgid "Cycle cursor tracking mode"
msgstr "사이클 커서 추적 모드"

#: addon/globalPlugins/terminalAccess.py:6501
msgid "Cursor tracking off"
msgstr "커서 추적 해제"

#: addon/globalPlugins/terminalAccess.py:6502
msgid "Standard cursor tracking"
msgstr "표준 커서 추적"

#: addon/globalPlugins/terminalAccess.py:6503
msgid "Highlight tracking"
msgstr "하이라이트 추적"

#: addon/globalPlugins/terminalAccess.py:6504
msgid "Window tracking"
msgstr "창 추적"

#: addon/globalPlugins/terminalAccess.py:6506
msgid "Unknown mode"
msgstr "알 수 없는 모드"

# Description for setting screen window
#: addon/globalPlugins/terminalAccess.py:6510
msgid "Set screen window boundaries"
msgstr "화면 창 경계 설정"

#: addon/globalPlugins/terminalAccess.py:6523
msgid "Unable to set window"
msgstr "창을 설정할 수 없습니다"

# Message when window start is set
#: addon/globalPlugins/terminalAccess.py:6531
msgid "Window start set. Move to end position and press again."
msgstr "창 시작 위치 설정. 끝 위치로 이동한 후 다시 누르세요."

# Message when window is defined
#: addon/globalPlugins/terminalAccess.py:6543
msgid "Window defined"
msgstr "창 정의"

# Description for clearing screen window
#: addon/globalPlugins/terminalAccess.py:6550
msgid "Clear screen window"
msgstr "창문 유리"

# Message when window is cleared
#: addon/globalPlugins/terminalAccess.py:6563
msgid "Window cleared"
msgstr "창이 비워졌습니다"

# Description for reading window content
#: addon/globalPlugins/terminalAccess.py:6567
msgid "Read window content"
msgstr "창 내용 읽기"

# Message when no window is defined
#: addon/globalPlugins/terminalAccess.py:6579
msgid "No window defined"
msgstr "정의된 창이 없습니다."

#: addon/globalPlugins/terminalAccess.py:6585
msgid "Unable to read window"
msgstr "창을 읽을 수 없습니다"

#: addon/globalPlugins/terminalAccess.py:6596
msgid "Window not properly defined"
msgstr "창이 올바르게 정의되지 않았습니다."

# Message when window contains no text
#: addon/globalPlugins/terminalAccess.py:6636
msgid "Window is empty"
msgstr "창이 비어 있습니다"

# Description for reading text attributes
#: addon/globalPlugins/terminalAccess.py:6643
msgid "Read text attributes at cursor"
msgstr "커서 위치의 텍스트 속성 읽기"

#: addon/globalPlugins/terminalAccess.py:6656
msgid "Unable to read attributes"
msgstr "속성을 읽을 수 없습니다"

# Message when no text at cursor
#: addon/globalPlugins/terminalAccess.py:6683
msgid "No text at cursor"
msgstr "커서 위치에 텍스트 없음"

# Description for continuous reading (say all)
#: addon/globalPlugins/terminalAccess.py:6694
msgid "Read continuously from cursor to end of buffer"
msgstr "커서 위치부터 버퍼 끝까지 연속적으로 읽기"

# Message when unable to start continuous reading
#: addon/globalPlugins/terminalAccess.py:6708
msgid "Unable to read"
msgstr "읽을 수 없음"

# Message when buffer is empty
#: addon/globalPlugins/terminalAccess.py:6721
msgid "Nothing to read"
msgstr "읽을 게 없다"

# Description for jumping to start of line
#: addon/globalPlugins/terminalAccess.py:6734
msgid "Move to first character of current line"
msgstr "현재 줄의 첫 번째 문자로 이동"

# Message when unable to move
#: addon/globalPlugins/terminalAccess.py:6748
msgid "Unable to move"
msgstr "움직일 수 없음"

# Message for blank line
#: addon/globalPlugins/terminalAccess.py:6766
msgid "Blank"
msgstr "빈칸"

# Description for jumping to end of line
#: addon/globalPlugins/terminalAccess.py:6772
msgid "Move to last character of current line"
msgstr "현재 줄의 마지막 문자로 이동"

# Description for jumping to top
#: addon/globalPlugins/terminalAccess.py:6811
msgid "Move to top of terminal buffer"
msgstr "터미널 버퍼 맨 위로 이동"

# Description for jumping to bottom
#: addon/globalPlugins/terminalAccess.py:6844
msgid "Move to bottom of terminal buffer"
msgstr "터미널 버퍼의 맨 아래로 이동"

# Description for announcing position
#: addon/globalPlugins/terminalAccess.py:6877
msgid "Announce current row and column position"
msgstr "현재 행과 열 위치를 알립니다"

# Message when position unavailable
#: addon/globalPlugins/terminalAccess.py:6891
msgid "Position unavailable"
msgstr "해당 직책은 현재 공석이 아닙니다."

# Description for announcing active profile
#: addon/globalPlugins/terminalAccess.py:6908
msgid "Announce which profile is currently active and which is set as default"
msgstr "현재 활성화된 프로필과 기본값으로 설정된 프로필을 알려줍니다."

# Message when no profile is active
#: addon/globalPlugins/terminalAccess.py:6923
msgid "None (using global settings)"
msgstr "없음 (글로벌 설정 사용)"

# Message when no default profile is set
#: addon/globalPlugins/terminalAccess.py:6932
msgid "None"
msgstr "없음"

# Message announcing active and default profiles
#: addon/globalPlugins/terminalAccess.py:6936
#, python-brace-format
msgid "Active profile: {active}. Default profile: {default}"
msgstr "활성 프로필: {active} 기본 프로필: {default}"

# Message when unable to read indentation
#: addon/globalPlugins/terminalAccess.py:6947
msgid "Unable to read indentation"
msgstr "들여쓰기를 읽을 수 없음"

# Message for empty line
#: addon/globalPlugins/terminalAccess.py:6957
msgid "Empty line"
msgstr "빈 줄"

# Message when line has no indentation
#: addon/globalPlugins/terminalAccess.py:6982
msgid "No indentation"
msgstr "들여쓰기 없음"

