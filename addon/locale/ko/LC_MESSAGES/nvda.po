# Message for mixed indentation
#: addon/globalPlugins/terminalAccess.py:6985
#, python-brace-format
msgid "{tabs} tabs, {spaces} spaces"
msgstr "{tabs} 탭, {spaces} 공백"

# Message for tab indentation
#: addon/globalPlugins/terminalAccess.py:6988
#, python-brace-format
msgid "{count} tab"
msgstr "{count} 탭"

# Message for tab indentation
#: addon/globalPlugins/terminalAccess.py:6988
#, python-brace-format
msgid "{count} tabs"
msgstr "{count} 탭"

# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
msgid "{count} space"
msgstr "{count} 공간"

# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
msgid "{count} spaces"
msgstr "{count} 공백"

# Message when no review position
#: addon/globalPlugins/terminalAccess.py:7097
msgid "No review position"
msgstr "검토 위치 없음"

#: addon/globalPlugins/terminalAccess.py:7103
msgid "Unable to read character"
msgstr "문자를 읽을 수 없습니다"

# Message when at edge of text
#: addon/globalPlugins/terminalAccess.py:7123
msgid "Edge"
msgstr "에지"

# Message when at edge of text
#: addon/globalPlugins/terminalAccess.py:7123
msgid "Top"
msgstr "최상위"

# Message when no character at position
#: addon/globalPlugins/terminalAccess.py:7175
msgid "No character"
msgstr "문자 없음"

# Message announcing character code
#: addon/globalPlugins/terminalAccess.py:7196
#, python-brace-format
msgid "Character {decimal}, hex {hex}, {name}"
msgstr "문자{decimal}, 16진수{hex}, {name}"

#: addon/globalPlugins/terminalAccess.py:7258
msgid "space"
msgstr "공간"

# Description for decreasing punctuation level
#: addon/globalPlugins/terminalAccess.py:7266
msgid "Decrease punctuation level"
msgstr "구두점 수준 낮추기"

#: addon/globalPlugins/terminalAccess.py:7284
