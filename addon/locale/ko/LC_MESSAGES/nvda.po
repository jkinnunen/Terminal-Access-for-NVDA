msgstr "구두점 수준 없음"

#: addon/globalPlugins/terminalAccess.py:7285
msgid "Punctuation level some"
msgstr "구두점 수준 일부"

#: addon/globalPlugins/terminalAccess.py:7286
msgid "Punctuation level most"
msgstr "구두점 수준 최고"

#: addon/globalPlugins/terminalAccess.py:7287
msgid "Punctuation level all"
msgstr "구두점 수준 모두"

#: addon/globalPlugins/terminalAccess.py:7289
msgid "Punctuation level unknown"
msgstr "구두점 수준 불명"

# Description for increasing punctuation level
#: addon/globalPlugins/terminalAccess.py:7293
msgid "Increase punctuation level"
msgstr "구두점 수준 높이기"

# Description for reading to left edge
#: addon/globalPlugins/terminalAccess.py:7320
msgid "Read from cursor to beginning of line"
msgstr "커서 위치부터 줄 시작 부분까지 읽기"

# Message when region is empty
#: addon/globalPlugins/terminalAccess.py:7346
msgid "Nothing"
msgstr "아무것도"

# Description for reading to right edge
#: addon/globalPlugins/terminalAccess.py:7356
msgid "Read from cursor to end of line"
msgstr "커서 위치부터 줄 끝까지 읽기"

# Description for reading to top
#: addon/globalPlugins/terminalAccess.py:7391
msgid "Read from cursor to top of buffer"
msgstr "커서 위치부터 버퍼 상단까지 읽기"

# Description for reading to bottom
#: addon/globalPlugins/terminalAccess.py:7428
msgid "Read from cursor to bottom of buffer"
msgstr "커서 위치부터 버퍼 끝까지 읽기"

# Description for toggling mark position
#: addon/globalPlugins/terminalAccess.py:7465
msgid "Toggle mark for selection (enhanced)"
msgstr "선택 표시 토글 (강화됨)"

#: addon/globalPlugins/terminalAccess.py:7478
