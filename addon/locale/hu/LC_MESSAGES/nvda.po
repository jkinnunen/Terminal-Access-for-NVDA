#: addon/globalPlugins/terminalAccess.py:121
msgid "Terminal Access"
msgstr "Terminál hozzáférés"

#: addon/globalPlugins/terminalAccess.py:2326
#, python-brace-format
msgid "Selection too large: {rows} rows exceeds maximum of {max}"
msgstr ""
"Túl nagy kiválasztás: {rows} sor meghaladja a maximális {max} értéket."

#: addon/globalPlugins/terminalAccess.py:2331
#, python-brace-format
msgid "Selection too wide: {cols} columns exceeds maximum of {max}"
msgstr ""
"Túl széles kiválasztás: az {cols} oszlopok meghaladják a {max} maximális "
"értékét."

#: addon/globalPlugins/terminalAccess.py:3050
msgid "Initializing..."
msgstr "Kezdődik..."

# Summary when many new lines arrive at once
#: addon/globalPlugins/terminalAccess.py:3377
#, python-brace-format
msgid "{n} new lines"
msgstr "{n} új sorok"

# Title for URL list dialog
#: addon/globalPlugins/terminalAccess.py:4936
msgid "URL List - Terminal Access"
msgstr "URL-lista – Terminál hozzáférés"

# Label for URL filter text box
#: addon/globalPlugins/terminalAccess.py:4948
msgid "&Filter:"
msgstr "&Szűrő:"

# Column header for URL list index
#: addon/globalPlugins/terminalAccess.py:4958
msgid "#"
msgstr "#"

# Column header for URL
#: addon/globalPlugins/terminalAccess.py:4960
msgid "URL"
msgstr "URL"

# Column header for line number
#: addon/globalPlugins/terminalAccess.py:4962
msgid "Line"
msgstr "Vonal"

# Column header for line context
#: addon/globalPlugins/terminalAccess.py:4964
msgid "Context"
msgstr "Kontextus"

# Button to open URL in browser
#: addon/globalPlugins/terminalAccess.py:4971
msgid "&Open"
msgstr "&Nyitva"

# Button to copy URL to clipboard
#: addon/globalPlugins/terminalAccess.py:4973
msgid "&Copy URL"
msgstr "&URL másolása"

# Button to move cursor to URL line
#: addon/globalPlugins/terminalAccess.py:4975
msgid "&Move to line"
msgstr "&Sorra lépés"

#: addon/globalPlugins/terminalAccess.py:4977
msgid "Close"
msgstr "Bezárás"

# Announced after URL is copied
#: addon/globalPlugins/terminalAccess.py:5058
msgid "URL copied"
msgstr "URL másolva"

# Announced when moving to a URL line
#: addon/globalPlugins/terminalAccess.py:5069
#, python-brace-format
msgid "Line {num}: {text}"
msgstr "{num} sor: {text}"

# Position context for verbose mode
#: addon/globalPlugins/terminalAccess.py:5443
#, python-brace-format
msgid "Row {row}, column {col}"
msgstr "{row} sor, {col} oszlop"

# Format for verbose announcements with context
#: addon/globalPlugins/terminalAccess.py:5481
#, python-brace-format
msgid "{message}. {context}"
msgstr "{message}. {context}"

# Message announced when entering a terminal application
#: addon/globalPlugins/terminalAccess.py:5587
msgid "Terminal Access support active. Press NVDA+shift+f1 for help."
msgstr ""
"Terminál hozzáférés támogatása aktív. Segítségért nyomja meg az "
"NVDA+shift+f1 billentyűkombinációt."

# Message format for repeated symbols, e.g. "3 dash"
#: addon/globalPlugins/terminalAccess.py:5717
#, python-brace-format
msgid "{count} {symbol}"
msgstr "{count} {symbol}"

#: addon/globalPlugins/terminalAccess.py:5930
#, python-brace-format
msgid "Highlighted: {text}"
msgstr "Kiemelve: {text}"

# Description for the show help gesture
#: addon/globalPlugins/terminalAccess.py:6018
msgid "Opens the Terminal Access user guide"
msgstr "Megnyitja a Terminál hozzáférés felhasználói útmutatót"

# Error message when help file is not found
#: addon/globalPlugins/terminalAccess.py:6033
msgid "Help file not found. Please reinstall the add-on."
msgstr "A súgó fájl nem található. Kérjük, telepítse újra a kiegészítőt."

# Error message when add-on is not properly installed
#: addon/globalPlugins/terminalAccess.py:6036
msgid "Terminal Access add-on not properly installed."
msgstr "A Terminal Access kiegészítő nem megfelelően van telepítve."

# Description for reading the previous line
#: addon/globalPlugins/terminalAccess.py:6040
msgid "Read previous line in terminal"
msgstr "Olvassa be az előző sort a terminálba"

# Description for reading the current line
#: addon/globalPlugins/terminalAccess.py:6054
msgid "Read current line in terminal. Press twice for indentation level."
msgstr ""
"Olvassa be az aktuális sort a terminálba. Kétszer nyomja meg a behúzás "
"szintjének beállításához."

# Description for reading the next line
#: addon/globalPlugins/terminalAccess.py:6073
msgid "Read next line in terminal"
msgstr "Olvassa el a következő sort a terminálban"

# Description for reading the previous word
#: addon/globalPlugins/terminalAccess.py:6087
msgid "Read previous word in terminal"
msgstr "Előző szó olvasása a terminálban"

# Description for reading the current word
#: addon/globalPlugins/terminalAccess.py:6101
msgid "Read current word in terminal"
msgstr "Olvassa el az aktuális szót a terminálban"

# Description for spelling the current word
#: addon/globalPlugins/terminalAccess.py:6115
msgid "Spell current word in terminal"
msgstr "A jelenlegi szó leírása a terminálban"

# Description for reading the next word
#: addon/globalPlugins/terminalAccess.py:6129
msgid "Read next word in terminal"
msgstr "Olvassa el a következő szót a terminálban"

# Description for reading the previous character
#: addon/globalPlugins/terminalAccess.py:6143
msgid "Read previous character in terminal"
msgstr "Olvassa be az előző karaktert a terminálba"

# Description for reading the current character
#: addon/globalPlugins/terminalAccess.py:6157
msgid ""
"Read current character in terminal. Press twice for phonetic. Press three "
"times for character code."
msgstr ""
"Olvassa be az aktuális karaktert a terminálban. Kétszer nyomja meg a "
"hangjelzéshez. Háromszor nyomja meg a karakterkódhoz."

# Description for reading the next character
#: addon/globalPlugins/terminalAccess.py:6181
msgid "Read next character in terminal"
msgstr "Olvassa be a következő karaktert a terminálban"

# Description for toggling quiet mode
#: addon/globalPlugins/terminalAccess.py:6195
msgid "Toggle quiet mode in terminal"
msgstr "Csendes mód bekapcsolása a terminálban"

# Message when quiet mode is enabled
#: addon/globalPlugins/terminalAccess.py:6215
msgid "Quiet mode on"
msgstr "Csendes mód bekapcsolva"

# Message when quiet mode is disabled
#: addon/globalPlugins/terminalAccess.py:6218
msgid "Quiet mode off"
msgstr "Csendes mód ki"

# Description for toggling announce new output
#: addon/globalPlugins/terminalAccess.py:6222
msgid "Toggle announce new output in terminal"
msgstr "Kapcsolja be az új kimenet bejelentését a terminálban"

# Message when announce new output is enabled
#: addon/globalPlugins/terminalAccess.py:6246
msgid "Announce new output on"
msgstr "Új kiadvány bejelentése"

# Message when announce new output is disabled
#: addon/globalPlugins/terminalAccess.py:6251
msgid "Announce new output off"
msgstr "Új kimenet bejelentése ki"

# Description for toggling indentation announcement
#: addon/globalPlugins/terminalAccess.py:6255
msgid "Toggle indentation announcement on line read in terminal"
msgstr "A behúzás bejelentésének bekapcsolása a terminálban olvasott sorban"

# Message when indentation announcement is enabled
#: addon/globalPlugins/terminalAccess.py:6273
msgid "Indentation announcement on"
msgstr "Behúzás bejelentése"

# Message when indentation announcement is disabled
#: addon/globalPlugins/terminalAccess.py:6276
msgid "Indentation announcement off"
msgstr "Behúzás bejelentés ki"

# Description for copy mode
#: addon/globalPlugins/terminalAccess.py:6280
msgid "Enter copy mode in terminal"
msgstr "Lépjen be a másolási módba a terminálban"

# Message entering copy mode
#: addon/globalPlugins/terminalAccess.py:6297
msgid ""
"Copy mode. Press L to copy line, S to copy screen, or Escape to cancel."
msgstr ""
"Másolási mód. Nyomja meg az L gombot a sor másolásához, az S gombot a "
"képernyő másolásához, vagy az Escape gombot a művelet megszakításához."

# Description for copying line
#: addon/globalPlugins/terminalAccess.py:6301
msgid "Copy line in copy mode"
msgstr "Sor másolása másolási módban"

#: addon/globalPlugins/terminalAccess.py:6313
msgid "Unable to copy"
msgstr "Másolás nem lehetséges"

# Message when line is copied
#: addon/globalPlugins/terminalAccess.py:6321
msgid "Line copied"
msgstr "Sor másolva"

# Description for copying screen
#: addon/globalPlugins/terminalAccess.py:6332
msgid "Copy screen in copy mode"
msgstr "Másolás módban a képernyő másolása"

# Message when screen is copied
#: addon/globalPlugins/terminalAccess.py:6352
msgid "Screen copied"
msgstr "Képernyő másolva"

# Description for exiting copy mode
#: addon/globalPlugins/terminalAccess.py:6363
msgid "Exit copy mode"
msgstr "Kilépés a másolási módból"

# Message when copy mode is canceled
#: addon/globalPlugins/terminalAccess.py:6373
msgid "Copy mode canceled"
msgstr "Másolási mód törölve"

# Description for toggling the command layer
#: addon/globalPlugins/terminalAccess.py:6401
msgid "Toggle terminal command layer (single-key command mode)"
msgstr "Terminálparancs-réteg váltása (egygombos parancs mód)"

# Announced when the terminal command layer is activated
#: addon/globalPlugins/terminalAccess.py:6430
msgid "Terminal commands"
msgstr "Terminál parancsok"

# Announced when the terminal command layer is deactivated
#: addon/globalPlugins/terminalAccess.py:6444
msgid "Exit terminal commands"
msgstr "Kilépés a terminál parancsokból"

# Description for exiting the command layer
#: addon/globalPlugins/terminalAccess.py:6448
msgid "Exit the terminal command layer"
msgstr "Kilépés a terminál parancssorból"

# Description for opening terminal settings
#: addon/globalPlugins/terminalAccess.py:6460
msgid "Open Terminal Access settings"
msgstr "Nyissa meg a Terminál hozzáférés beállításait"

# Error message when settings dialog cannot be opened
#: addon/globalPlugins/terminalAccess.py:6474
msgid "Unable to open settings dialog. Please try again."
msgstr ""
"A beállítások párbeszédablak nem nyitható meg. Kérjük, próbálkozzon újra."

# Description for cycling cursor tracking modes
#: addon/globalPlugins/terminalAccess.py:6478
msgid "Cycle cursor tracking mode"
msgstr "Ciklus kurzor követési mód"

#: addon/globalPlugins/terminalAccess.py:6501
msgid "Cursor tracking off"
msgstr "Körző követés ki"

#: addon/globalPlugins/terminalAccess.py:6502
msgid "Standard cursor tracking"
msgstr "Normál kurzor követés"

#: addon/globalPlugins/terminalAccess.py:6503
msgid "Highlight tracking"
msgstr "Kiemelt követés"

#: addon/globalPlugins/terminalAccess.py:6504
msgid "Window tracking"
msgstr "Ablakkövetés"

#: addon/globalPlugins/terminalAccess.py:6506
msgid "Unknown mode"
msgstr "Ismeretlen mód"

# Description for setting screen window
#: addon/globalPlugins/terminalAccess.py:6510
msgid "Set screen window boundaries"
msgstr "A képernyőablak határainak beállítása"

#: addon/globalPlugins/terminalAccess.py:6523
msgid "Unable to set window"
msgstr "Az ablak beállítása nem lehetséges"

# Message when window start is set
#: addon/globalPlugins/terminalAccess.py:6531
msgid "Window start set. Move to end position and press again."
msgstr ""
"Ablak indítási beállítás. Mozgassa a végpozícióba, és nyomja meg újra."

# Message when window is defined
#: addon/globalPlugins/terminalAccess.py:6543
msgid "Window defined"
msgstr "Ablak meghatározása"

# Description for clearing screen window
#: addon/globalPlugins/terminalAccess.py:6550
msgid "Clear screen window"
msgstr "Tiszta képernyő ablak"

# Message when window is cleared
#: addon/globalPlugins/terminalAccess.py:6563
msgid "Window cleared"
msgstr "Ablak törölve"

# Description for reading window content
#: addon/globalPlugins/terminalAccess.py:6567
msgid "Read window content"
msgstr "Ablak tartalmának olvasása"

# Message when no window is defined
#: addon/globalPlugins/terminalAccess.py:6579
msgid "No window defined"
msgstr "Nincs definiált ablak"

#: addon/globalPlugins/terminalAccess.py:6585
msgid "Unable to read window"
msgstr "Az ablak nem olvasható"

#: addon/globalPlugins/terminalAccess.py:6596
msgid "Window not properly defined"
msgstr "Az ablak nincs megfelelően definiálva"

# Message when window contains no text
#: addon/globalPlugins/terminalAccess.py:6636
msgid "Window is empty"
msgstr "Az ablak üres"

# Description for reading text attributes
#: addon/globalPlugins/terminalAccess.py:6643
msgid "Read text attributes at cursor"
msgstr "Olvassa el a kurzor alatt található szöveg attribútumait"

#: addon/globalPlugins/terminalAccess.py:6656
msgid "Unable to read attributes"
msgstr "Az attribútumok olvasása nem lehetséges"

# Message when no text at cursor
#: addon/globalPlugins/terminalAccess.py:6683
msgid "No text at cursor"
msgstr "Nincs szöveg a kurzor alatt"

# Description for continuous reading (say all)
#: addon/globalPlugins/terminalAccess.py:6694
msgid "Read continuously from cursor to end of buffer"
msgstr "Olvassa folyamatosan a kurzortól a puffer végéig"

# Message when unable to start continuous reading
#: addon/globalPlugins/terminalAccess.py:6708
msgid "Unable to read"
msgstr "Nem olvasható"

# Message when buffer is empty
#: addon/globalPlugins/terminalAccess.py:6721
msgid "Nothing to read"
msgstr "Nincs mit olvasni"

# Description for jumping to start of line
#: addon/globalPlugins/terminalAccess.py:6734
msgid "Move to first character of current line"
msgstr "Az aktuális sor első karakteréhez lépés"

# Message when unable to move
#: addon/globalPlugins/terminalAccess.py:6748
msgid "Unable to move"
msgstr "Nem tud mozogni"

# Message for blank line
#: addon/globalPlugins/terminalAccess.py:6766
msgid "Blank"
msgstr "Üres"

# Description for jumping to end of line
#: addon/globalPlugins/terminalAccess.py:6772
msgid "Move to last character of current line"
msgstr "Ugrás az aktuális sor utolsó karakteréhez"

# Description for jumping to top
#: addon/globalPlugins/terminalAccess.py:6811
msgid "Move to top of terminal buffer"
msgstr "A terminál puffer tetejére lépés"

# Description for jumping to bottom
#: addon/globalPlugins/terminalAccess.py:6844
msgid "Move to bottom of terminal buffer"
msgstr "A terminál puffer aljára lépés"

# Description for announcing position
#: addon/globalPlugins/terminalAccess.py:6877
msgid "Announce current row and column position"
msgstr "Jelenlegi sor és oszlop pozíciójának bejelentése"

# Message when position unavailable
#: addon/globalPlugins/terminalAccess.py:6891
msgid "Position unavailable"
msgstr "Pozíció nem elérhető"

# Description for announcing active profile
#: addon/globalPlugins/terminalAccess.py:6908
msgid "Announce which profile is currently active and which is set as default"
msgstr ""
"Jelentse be, melyik profil aktív jelenleg, és melyik van alapértelmezettként"
" beállítva."

# Message when no profile is active
#: addon/globalPlugins/terminalAccess.py:6923
msgid "None (using global settings)"
msgstr "Nincs (globális beállítások használata)"

# Message when no default profile is set
#: addon/globalPlugins/terminalAccess.py:6932
msgid "None"
msgstr "Nincs"

# Message announcing active and default profiles
#: addon/globalPlugins/terminalAccess.py:6936
#, python-brace-format
msgid "Active profile: {active}. Default profile: {default}"
msgstr "Aktív profil: {active}. Alapértelmezett profil: {default}"

# Message when unable to read indentation
#: addon/globalPlugins/terminalAccess.py:6947
msgid "Unable to read indentation"
msgstr "A behúzás nem olvasható"

# Message for empty line
#: addon/globalPlugins/terminalAccess.py:6957
msgid "Empty line"
msgstr "Üres sor"

# Message when line has no indentation
#: addon/globalPlugins/terminalAccess.py:6982
msgid "No indentation"
msgstr "Nincs behúzás"

# Message for mixed indentation
#: addon/globalPlugins/terminalAccess.py:6985
#, python-brace-format
msgid "{tabs} tab, {spaces} spaces"
msgstr "{tabs} {spaces}"

# Message for mixed indentation
#: addon/globalPlugins/terminalAccess.py:6985
#, python-brace-format
msgid "{tabs} tabs, {spaces} spaces"
msgstr "{tabs} {spaces}"

# Message for tab indentation
#: addon/globalPlugins/terminalAccess.py:6988
#, python-brace-format
msgid "{count} tab"
msgstr "{count} fül"

# Message for tab indentation
#: addon/globalPlugins/terminalAccess.py:6988
#, python-brace-format
msgid "{count} tabs"
msgstr "{count} fülek"

# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
msgid "{count} space"
msgstr "{count} tér"

# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
msgid "{count} spaces"
msgstr "{count} tér"

# Message when no review position
#: addon/globalPlugins/terminalAccess.py:7097
msgid "No review position"
msgstr "Nincs véleményezési pozíció"

#: addon/globalPlugins/terminalAccess.py:7103
msgid "Unable to read character"
msgstr "Karakter olvasása nem lehetséges"

# Message when at edge of text
#: addon/globalPlugins/terminalAccess.py:7123
msgid "Edge"
msgstr "Él"

# Message when at edge of text
#: addon/globalPlugins/terminalAccess.py:7123
msgid "Top"
msgstr "Top"

# Message when no character at position
#: addon/globalPlugins/terminalAccess.py:7175
msgid "No character"
msgstr "Nincs karakter"

# Message announcing character code
#: addon/globalPlugins/terminalAccess.py:7196
#, python-brace-format
msgid "Character {decimal}, hex {hex}, {name}"
msgstr "Karakter{decimal}, hex{hex}, {name}"

#: addon/globalPlugins/terminalAccess.py:7258
msgid "space"
msgstr "tér"

# Description for decreasing punctuation level
#: addon/globalPlugins/terminalAccess.py:7266
msgid "Decrease punctuation level"
msgstr "Csökkentse az írásjelek szintjét"

#: addon/globalPlugins/terminalAccess.py:7284
msgid "Punctuation level none"
msgstr "Írásjelek szintje: nincs"

#: addon/globalPlugins/terminalAccess.py:7285
msgid "Punctuation level some"
msgstr "Írásjelek szintje néhány"

#: addon/globalPlugins/terminalAccess.py:7286
msgid "Punctuation level most"
msgstr "Írásjelek szintje legmagasabb"

#: addon/globalPlugins/terminalAccess.py:7287
msgid "Punctuation level all"
msgstr "Írásjelek szintje: mind"

#: addon/globalPlugins/terminalAccess.py:7289
msgid "Punctuation level unknown"
msgstr "Az írásjelek szintje ismeretlen"

# Description for increasing punctuation level
#: addon/globalPlugins/terminalAccess.py:7293
msgid "Increase punctuation level"
msgstr "Növelje az írásjelek szintjét"

# Description for reading to left edge
#: addon/globalPlugins/terminalAccess.py:7320
msgid "Read from cursor to beginning of line"
msgstr "Olvasás a kurzortól a sor elejéig"

# Message when region is empty
#: addon/globalPlugins/terminalAccess.py:7346
msgid "Nothing"
msgstr "Semmi"

# Description for reading to right edge
#: addon/globalPlugins/terminalAccess.py:7356
msgid "Read from cursor to end of line"
msgstr "Olvasás a kurzortól a sor végéig"

# Description for reading to top
#: addon/globalPlugins/terminalAccess.py:7391
msgid "Read from cursor to top of buffer"
msgstr "Olvasás a kurzortól a puffer tetejéig"

# Description for reading to bottom
#: addon/globalPlugins/terminalAccess.py:7428
msgid "Read from cursor to bottom of buffer"
msgstr "Olvasás a kurzortól a puffer aljáig"

# Description for toggling mark position
#: addon/globalPlugins/terminalAccess.py:7465
msgid "Toggle mark for selection (enhanced)"
msgstr "Jelölés a kiválasztáshoz (továbbfejlesztett)"

#: addon/globalPlugins/terminalAccess.py:7478
msgid "Unable to set mark"
msgstr "A jelölés nem állítható be"

# Message when start mark is set (Phase 6: Enhanced with context)
#: addon/globalPlugins/terminalAccess.py:7485
msgid "Mark start set"
msgstr "Kezdés jelölése"

# Message when end mark is set (Phase 6: Enhanced with context)
#: addon/globalPlugins/terminalAccess.py:7490
msgid "Mark end set"
msgstr "Végjelölés beállítása"

# Message when marks are cleared
#: addon/globalPlugins/terminalAccess.py:7496
msgid "Marks cleared"
msgstr "Jelölések törölve"

# Description for copying linear selection
#: addon/globalPlugins/terminalAccess.py:7502
msgid "Copy linear selection between marks"
msgstr "Lineáris kijelölés másolása jelek között"

# Message when marks are not set
#: addon/globalPlugins/terminalAccess.py:7514
msgid "Set start and end marks first"
msgstr "Először állítsa be a kezdő és végjeleket"

# Message when selection copied
#: addon/globalPlugins/terminalAccess.py:7531
msgid "Selection copied"
msgstr "Kiválasztás másolva"

#: addon/globalPlugins/terminalAccess.py:7537
msgid "Unable to copy: terminal not accessible"
msgstr "Másolás nem lehetséges: a terminál nem elérhető"

# Description for copying rectangular selection
#: addon/globalPlugins/terminalAccess.py:7545
msgid "Copy rectangular selection between marks"
msgstr "Négyszögletes kijelölés másolása jelek között"

#: addon/globalPlugins/terminalAccess.py:7575
msgid "Unable to determine position"
msgstr "A pozíció meghatározása nem lehetséges"

#: addon/globalPlugins/terminalAccess.py:7597
msgid "Background operation in progress, please wait"
msgstr "Háttérművelet folyamatban, kérjük, várjon!"

#: addon/globalPlugins/terminalAccess.py:7600
#, python-brace-format
msgid "Processing large selection ({rows} rows), please wait..."
msgstr "Nagy mennyiségű adat feldolgozása ({rows} sor), kérjük, várjon..."

#: addon/globalPlugins/terminalAccess.py:7607
msgid "Terminal Access - Copying Selection"
msgstr "Terminál hozzáférés - Kiválasztás másolása"

#: addon/globalPlugins/terminalAccess.py:7620
msgid "Failed to start background operation"
msgstr "A háttérművelet elindítása sikertelen"

#: addon/globalPlugins/terminalAccess.py:7658
msgid "Background copy failed: terminal not accessible"
msgstr "A háttér másolása sikertelen: a terminál nem érhető el"

#: addon/globalPlugins/terminalAccess.py:7664
msgid "Background copy failed"
msgstr "A háttér másolása sikertelen"

#: addon/globalPlugins/terminalAccess.py:7701
#, python-brace-format
msgid "Copying row {current} of {total}..."
msgstr "Az {total}... fájl {current} sorának másolása..."

#: addon/globalPlugins/terminalAccess.py:7706
msgid "Copy operation cancelled by user"
msgstr "A másolás műveletet a felhasználó törölte"

#: addon/globalPlugins/terminalAccess.py:7727
msgid "Copy complete!"
msgstr "Másolás befejezve!"

# Message for successful rectangular selection copy
#: addon/globalPlugins/terminalAccess.py:7732
#, python-brace-format
msgid "Rectangular selection copied: {rows} rows, columns {start} to {end}"
msgstr ""
"Téglalap alakú kijelölés másolva: {rows} sorok, oszlopok {start} és {end} "
"között"

# Description for clearing marks
#: addon/globalPlugins/terminalAccess.py:7751
msgid "Clear selection marks"
msgstr "Tiszta választási jelölések"

# Description for setting bookmark
#: addon/globalPlugins/terminalAccess.py:7770
msgid "Set a bookmark at the current review position (use with 0-9)"
msgstr ""
"Könyvjelző beállítása az aktuális felülvizsgálati pozícióban (0-9 "
"használatával)"

