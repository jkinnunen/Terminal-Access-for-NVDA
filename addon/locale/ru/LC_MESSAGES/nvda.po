#: addon/globalPlugins/terminalAccess.py:4958
msgid "#"
msgstr "#"

# Column header for URL
#: addon/globalPlugins/terminalAccess.py:4960
msgid "URL"
msgstr "URL"

# Column header for line number
#: addon/globalPlugins/terminalAccess.py:4962
msgid "Line"
msgstr "Линия"

# Column header for line context
#: addon/globalPlugins/terminalAccess.py:4964
msgid "Context"
msgstr "Контекст"

# Button to open URL in browser
#: addon/globalPlugins/terminalAccess.py:4971
msgid "&Open"
msgstr "&Открыть"

# Button to copy URL to clipboard
#: addon/globalPlugins/terminalAccess.py:4973
msgid "&Copy URL"
msgstr "&Копировать URL"

# Button to move cursor to URL line
#: addon/globalPlugins/terminalAccess.py:4975
msgid "&Move to line"
msgstr "&Перейти к строке"

#: addon/globalPlugins/terminalAccess.py:4977
msgid "Close"
msgstr "Закрыть"

# Announced after URL is copied
#: addon/globalPlugins/terminalAccess.py:5058
msgid "URL copied"
msgstr "URL скопирован"

# Announced when moving to a URL line
#: addon/globalPlugins/terminalAccess.py:5069
#, python-brace-format
msgid "Line {num}: {text}"
msgstr "Линия «{num}»: {text}"

# Position context for verbose mode
#: addon/globalPlugins/terminalAccess.py:5443
#, python-brace-format
msgid "Row {row}, column {col}"
msgstr "Строка{row}, столбец{col}"

# Format for verbose announcements with context
#: addon/globalPlugins/terminalAccess.py:5481
#, python-brace-format
msgid "{message}. {context}"
msgstr "{message}. {context}"

# Message announced when entering a terminal application
#: addon/globalPlugins/terminalAccess.py:5587
msgid "Terminal Access support active. Press NVDA+shift+f1 for help."
msgstr ""
"Поддержка доступа к терминалу активна. Нажмите NVDA+shift+f1 для получения "
"справки."

# Message format for repeated symbols, e.g. "3 dash"
#: addon/globalPlugins/terminalAccess.py:5717
#, python-brace-format
msgid "{count} {symbol}"
msgstr "{count} {symbol}"

#: addon/globalPlugins/terminalAccess.py:5930
#, python-brace-format
msgid "Highlighted: {text}"
msgstr "Выделено: {text}"

# Description for the show help gesture
#: addon/globalPlugins/terminalAccess.py:6018
msgid "Opens the Terminal Access user guide"
msgstr "Открывает руководство пользователя по доступу к терминалу"

# Error message when help file is not found
#: addon/globalPlugins/terminalAccess.py:6033
msgid "Help file not found. Please reinstall the add-on."
msgstr "Файл справки не найден. Пожалуйста, переустановите дополнение."

# Error message when add-on is not properly installed
#: addon/globalPlugins/terminalAccess.py:6036
msgid "Terminal Access add-on not properly installed."
msgstr "Дополнение Terminal Access установлено некорректно."

# Description for reading the previous line
#: addon/globalPlugins/terminalAccess.py:6040
msgid "Read previous line in terminal"
msgstr "Прочитать предыдущую строку в терминале"

# Description for reading the current line
#: addon/globalPlugins/terminalAccess.py:6054
msgid "Read current line in terminal. Press twice for indentation level."
msgstr ""
"Прочитать текущую строку в терминале. Нажмите дважды для уровня отступа."

# Description for reading the next line
#: addon/globalPlugins/terminalAccess.py:6073
msgid "Read next line in terminal"
msgstr "Прочитать следующую строку в терминале"

# Description for reading the previous word
#: addon/globalPlugins/terminalAccess.py:6087
msgid "Read previous word in terminal"
msgstr "Прочитать предыдущее слово в терминале"

# Description for reading the current word
#: addon/globalPlugins/terminalAccess.py:6101
msgid "Read current word in terminal"
msgstr "Прочитать текущее слово в терминале"

# Description for spelling the current word
#: addon/globalPlugins/terminalAccess.py:6115
msgid "Spell current word in terminal"
msgstr "Написать текущее слово в терминале"

# Description for reading the next word
#: addon/globalPlugins/terminalAccess.py:6129
msgid "Read next word in terminal"
msgstr "Прочитать следующее слово в терминале"

# Description for reading the previous character
#: addon/globalPlugins/terminalAccess.py:6143
msgid "Read previous character in terminal"
msgstr "Прочитать предыдущий символ в терминале"

# Description for reading the current character
#: addon/globalPlugins/terminalAccess.py:6157
msgid ""
"Read current character in terminal. Press twice for phonetic. Press three "
"times for character code."
msgstr ""
"Считывает текущий символ в терминале. Нажмите дважды для фонетического "
"значения. Нажмите трижды для кода символа."

# Description for reading the next character
#: addon/globalPlugins/terminalAccess.py:6181
msgid "Read next character in terminal"
msgstr "Прочитать следующий символ в терминале"

# Description for toggling quiet mode
#: addon/globalPlugins/terminalAccess.py:6195
msgid "Toggle quiet mode in terminal"
msgstr "Включить/выключить тихий режим в терминале"

# Message when quiet mode is enabled
#: addon/globalPlugins/terminalAccess.py:6215
msgid "Quiet mode on"
msgstr "Тихий режим включен"

# Message when quiet mode is disabled
#: addon/globalPlugins/terminalAccess.py:6218
msgid "Quiet mode off"
msgstr "Тихий режим выключен"

# Description for toggling announce new output
#: addon/globalPlugins/terminalAccess.py:6222
msgid "Toggle announce new output in terminal"
msgstr "Включить/выключить объявление о новом выводе в терминале"

# Message when announce new output is enabled
#: addon/globalPlugins/terminalAccess.py:6246
msgid "Announce new output on"
msgstr "Объявить о новой продукции на"

# Message when announce new output is disabled
#: addon/globalPlugins/terminalAccess.py:6251
msgid "Announce new output off"
msgstr "Объявить о новой продукции"

# Description for toggling indentation announcement
#: addon/globalPlugins/terminalAccess.py:6255
msgid "Toggle indentation announcement on line read in terminal"
msgstr ""
"Включить/выключить объявление об отступе в строке, прочитанной в терминале"

# Message when indentation announcement is enabled
#: addon/globalPlugins/terminalAccess.py:6273
msgid "Indentation announcement on"
msgstr "Объявление об отступе на"

# Message when indentation announcement is disabled
#: addon/globalPlugins/terminalAccess.py:6276
msgid "Indentation announcement off"
msgstr "Отступление объявления выключено"

# Description for copy mode
#: addon/globalPlugins/terminalAccess.py:6280
msgid "Enter copy mode in terminal"
msgstr "Введите режим копирования в терминале"

# Message entering copy mode
#: addon/globalPlugins/terminalAccess.py:6297
msgid ""
"Copy mode. Press L to copy line, S to copy screen, or Escape to cancel."
msgstr ""
"Режим копирования. Нажмите L, чтобы скопировать строку, S, чтобы скопировать"
" экран, или Escape, чтобы отменить."

# Description for copying line
#: addon/globalPlugins/terminalAccess.py:6301
msgid "Copy line in copy mode"
msgstr "Копировать строку в режиме копирования"

#: addon/globalPlugins/terminalAccess.py:6313
msgid "Unable to copy"
msgstr "Невозможно скопировать"

# Message when line is copied
#: addon/globalPlugins/terminalAccess.py:6321
msgid "Line copied"
msgstr "Строка скопирована"

# Description for copying screen
#: addon/globalPlugins/terminalAccess.py:6332
msgid "Copy screen in copy mode"
msgstr "Копировать экран в режиме копирования"

# Message when screen is copied
#: addon/globalPlugins/terminalAccess.py:6352
msgid "Screen copied"
msgstr "Экран скопирован"

# Description for exiting copy mode
#: addon/globalPlugins/terminalAccess.py:6363
msgid "Exit copy mode"
msgstr "Выход из режима копирования"

# Message when copy mode is canceled
#: addon/globalPlugins/terminalAccess.py:6373
msgid "Copy mode canceled"
msgstr "Режим копирования отменен"

# Description for toggling the command layer
#: addon/globalPlugins/terminalAccess.py:6401
msgid "Toggle terminal command layer (single-key command mode)"
msgstr "Переключение уровня команд терминала (режим команд одной клавишей)"

# Announced when the terminal command layer is activated
#: addon/globalPlugins/terminalAccess.py:6430
msgid "Terminal commands"
msgstr "Команды терминала"

# Announced when the terminal command layer is deactivated
#: addon/globalPlugins/terminalAccess.py:6444
msgid "Exit terminal commands"
msgstr "Команды терминала выхода"

# Description for exiting the command layer
#: addon/globalPlugins/terminalAccess.py:6448
msgid "Exit the terminal command layer"
msgstr "Выход из командного слоя терминала"

# Description for opening terminal settings
#: addon/globalPlugins/terminalAccess.py:6460
msgid "Open Terminal Access settings"
msgstr "Открыть настройки доступа к терминалу"

# Error message when settings dialog cannot be opened
#: addon/globalPlugins/terminalAccess.py:6474
msgid "Unable to open settings dialog. Please try again."
msgstr "Невозможно открыть диалоговое окно настроек. Повторите попытку."

# Description for cycling cursor tracking modes
#: addon/globalPlugins/terminalAccess.py:6478
msgid "Cycle cursor tracking mode"
msgstr "Режим отслеживания курсора цикла"

#: addon/globalPlugins/terminalAccess.py:6501
msgid "Cursor tracking off"
msgstr "Отслеживание курсора выключено"

#: addon/globalPlugins/terminalAccess.py:6502
msgid "Standard cursor tracking"
msgstr "Стандартное отслеживание курсора"

#: addon/globalPlugins/terminalAccess.py:6503
msgid "Highlight tracking"
msgstr "Отслеживание выделения"

#: addon/globalPlugins/terminalAccess.py:6504
msgid "Window tracking"
msgstr "Отслеживание окон"

#: addon/globalPlugins/terminalAccess.py:6506
msgid "Unknown mode"
msgstr "Неизвестный режим"

# Description for setting screen window
#: addon/globalPlugins/terminalAccess.py:6510
msgid "Set screen window boundaries"
msgstr "Установить границы окна экрана"

#: addon/globalPlugins/terminalAccess.py:6523
msgid "Unable to set window"
msgstr "Невозможно установить окно"

