msgstr "Перейти к первому символу текущей строки"

# Message when unable to move
#: addon/globalPlugins/terminalAccess.py:6748
msgid "Unable to move"
msgstr "Невозможность двигаться"

# Message for blank line
#: addon/globalPlugins/terminalAccess.py:6766
msgid "Blank"
msgstr "Пустой"

