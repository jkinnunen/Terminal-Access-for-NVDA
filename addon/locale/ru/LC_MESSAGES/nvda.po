msgstr "Определение окна"

# Description for clearing screen window
#: addon/globalPlugins/terminalAccess.py:6550
msgid "Clear screen window"
msgstr "Очистить окно экрана"

# Message when window is cleared
#: addon/globalPlugins/terminalAccess.py:6563
msgid "Window cleared"
msgstr "Окно очищено"

# Description for reading window content
#: addon/globalPlugins/terminalAccess.py:6567
