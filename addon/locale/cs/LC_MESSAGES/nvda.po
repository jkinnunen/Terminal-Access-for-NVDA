msgstr "Profily aplikací"

#: addon/globalPlugins/terminalAccess.py:8554
msgid "Installed &profiles:"
msgstr "Nainstalované profily:"

# Tooltip for profile list
#: addon/globalPlugins/terminalAccess.py:8561
msgid ""
"Select an application profile to view or edit. Profiles customize Terminal "
"Access behavior for specific applications. Active and default profiles are "
"marked."
msgstr ""
"Vyberte profil aplikace, který chcete zobrazit nebo upravit. Profily "
