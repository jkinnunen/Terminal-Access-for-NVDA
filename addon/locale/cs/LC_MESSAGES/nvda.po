# Description for toggling mark position
#: addon/globalPlugins/terminalAccess.py:7465
msgid "Toggle mark for selection (enhanced)"
msgstr "Přepínat značku pro výběr (vylepšené)"

#: addon/globalPlugins/terminalAccess.py:7478
msgid "Unable to set mark"
msgstr "Nelze nastavit značku"

