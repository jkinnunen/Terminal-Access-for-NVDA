#: addon/globalPlugins/terminalAccess.py:7285
msgid "Punctuation level some"
msgstr "Úroveň interpunkce některé"

#: addon/globalPlugins/terminalAccess.py:7286
msgid "Punctuation level most"
msgstr "Úroveň interpunkce nejvíce"

#: addon/globalPlugins/terminalAccess.py:7287
