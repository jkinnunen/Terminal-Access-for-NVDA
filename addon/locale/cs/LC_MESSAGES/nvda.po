msgstr "Nejprve nastavte značky začátku a konce"

# Message when selection copied
#: addon/globalPlugins/terminalAccess.py:7531
msgid "Selection copied"
msgstr "Výběr zkopírován"

#: addon/globalPlugins/terminalAccess.py:7537
msgid "Unable to copy: terminal not accessible"
msgstr "Nelze kopírovat: terminál není přístupný"

# Description for copying rectangular selection
#: addon/globalPlugins/terminalAccess.py:7545
msgid "Copy rectangular selection between marks"
msgstr "Kopírování obdélníkového výběru mezi značkami"

#: addon/globalPlugins/terminalAccess.py:7575
msgid "Unable to determine position"
msgstr "Nelze určit polohu"

