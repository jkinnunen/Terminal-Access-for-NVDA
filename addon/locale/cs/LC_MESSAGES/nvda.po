# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
msgid "{count} space"
msgstr "{count} prostor"

# Message for space indentation
#: addon/globalPlugins/terminalAccess.py:6991
#, python-brace-format
