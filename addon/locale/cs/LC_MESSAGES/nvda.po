msgstr "Sledování kurzoru"

#: addon/globalPlugins/terminalAccess.py:8316
msgid "Enable cursor &tracking"
msgstr "Povolit kurzor a sledování"

# Tooltip for cursor tracking checkbox
#: addon/globalPlugins/terminalAccess.py:8320
msgid "Automatically announce cursor position changes in the terminal"
msgstr "Automaticky oznamovat změny polohy kurzoru v terminálu"

#: addon/globalPlugins/terminalAccess.py:8327
msgid "Cursor tracking &mode:"
msgstr "Sledování kurzoru a režim:"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8331
msgid "Off"
msgstr "Vypnuto"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8333
msgid "Standard"
msgstr "Standard"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8335
msgid "Highlight"
msgstr "Zvýraznění"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8337
msgid "Window"
msgstr "Okno"

# Tooltip for cursor tracking mode
#: addon/globalPlugins/terminalAccess.py:8342
msgid ""
"Standard: announce line/column changes, Highlight: announce highlighted "
"text, Window: only announce within defined window"
msgstr ""
"Standardní: oznamovat změny řádků/sloupců, Zvýraznění: oznamovat zvýrazněný "
"text, Okno: oznamovat pouze v rámci definovaného okna"

#: addon/globalPlugins/terminalAccess.py:8351
msgid "Cursor delay (milliseconds):"
msgstr "Zpoždění kurzoru (milisekundy):"

# Tooltip for cursor delay
#: addon/globalPlugins/terminalAccess.py:8358
msgid ""
"Delay before announcing cursor position (0-1000ms). Higher values reduce "
"announcement frequency."
msgstr ""
"Zpoždění před oznámením polohy kurzoru (0–1000 ms). Vyšší hodnoty snižují "
"frekvenci oznámení."

#: addon/globalPlugins/terminalAccess.py:8366
msgid "Feedback"
msgstr "Zpětná vazba"

#: addon/globalPlugins/terminalAccess.py:8374
msgid "Enable &key echo"
msgstr "Povolit &key echo"

# Tooltip for key echo
#: addon/globalPlugins/terminalAccess.py:8378
msgid "Announce characters as you type in the terminal"
msgstr "Oznamujte znaky při psaní v terminálu"

#: addon/globalPlugins/terminalAccess.py:8385
msgid "Pause at &newlines"
msgstr "Pauza na &nové řádky"

# Tooltip for line pause
#: addon/globalPlugins/terminalAccess.py:8389
msgid "Brief pause when speaking line content to improve clarity"
msgstr "Krátká pauza při přednesu obsahu řádku pro zlepšení srozumitelnosti"

#: addon/globalPlugins/terminalAccess.py:8396
msgid "&Punctuation level:"
msgstr "&Úroveň interpunkce:"

# Punctuation level option
#: addon/globalPlugins/terminalAccess.py:8402
msgid "Some (.,?!;:)"
msgstr "Někteří (.,?!;:)"

# Punctuation level option
#: addon/globalPlugins/terminalAccess.py:8404
#, python-brace-format
msgid "Most (adds @#$%^&*()_+=[]{}\\\\|<>/)"
msgstr "Většina (přidává @#$%^&*()_+=[]{}\\\\|<>/)"

# Punctuation level option
#: addon/globalPlugins/terminalAccess.py:8406
msgid "All"
msgstr "Všechny"

# Tooltip for punctuation level
#: addon/globalPlugins/terminalAccess.py:8411
msgid ""
"Controls which punctuation symbols are announced. Higher levels announce "
"more symbols. Use NVDA+[ and ] to adjust quickly."
msgstr ""
"Ovládání, které interpunkční znaménka jsou oznamována. Vyšší úrovně oznamují"
" více znamének. Pomocí NVDA+[ a ] můžete nastavení rychle upravit."

#: addon/globalPlugins/terminalAccess.py:8420
msgid "&Quiet mode"
msgstr "&Tichý režim"

# Tooltip for quiet mode
#: addon/globalPlugins/terminalAccess.py:8424
msgid ""
"Suppress most Terminal Access announcements. Use NVDA+Shift+Q to toggle "
"quickly."
msgstr ""
"Potlačí většinu hlášení o přístupu k terminálu. Pomocí klávesové zkratky "
"NVDA+Shift+Q můžete tuto funkci rychle přepínat."

#: addon/globalPlugins/terminalAccess.py:8431
msgid "&Verbose mode (detailed feedback)"
msgstr "&Režim Verbose (podrobná zpětná vazba)"

# Tooltip for verbose mode
#: addon/globalPlugins/terminalAccess.py:8435
msgid ""
"Include position and context information with announcements. Useful for "
"debugging and understanding terminal layout."
msgstr ""
"Zahrňte do oznámení informace o poloze a kontextu. Užitečné pro ladění a "
"pochopení rozložení terminálu."

#: addon/globalPlugins/terminalAccess.py:8443
msgid "Announce &indentation when reading lines"
msgstr "Oznamovat odsazení při čtení řádků"

# Tooltip for indentation announcement
#: addon/globalPlugins/terminalAccess.py:8447
msgid ""
"Automatically announce indentation level when reading lines. Use NVDA+F5 to "
"toggle quickly. NVDA+I pressed twice still reads indentation."
msgstr ""
"Při čtení řádků automaticky oznamuje úroveň odsazení. Pomocí klávesy NVDA+F5"
" lze tuto funkci rychle přepínat. Dvojím stisknutím klávesy NVDA+I se stále "
"čte odsazení."

#: addon/globalPlugins/terminalAccess.py:8455
msgid "Announce New Output"
msgstr "Oznámit nový výstup"

#: addon/globalPlugins/terminalAccess.py:8463
msgid "&Announce new terminal output automatically"
msgstr "&Automaticky oznamovat nový výstup terminálu"

# Tooltip for announce new output
#: addon/globalPlugins/terminalAccess.py:8467
msgid ""
"Automatically speak newly appended terminal output as it arrives. Use "
"NVDA+Shift+N to toggle quickly."
msgstr ""
"Automaticky přečtěte nově připojený výstup terminálu, jakmile dorazí. Pomocí"
" klávesy NVDA+Shift+N můžete tuto funkci rychle přepínat."

#: addon/globalPlugins/terminalAccess.py:8475
msgid "&Coalesce delay (ms):"
msgstr "&Zpoždění koalescence (ms):"

# Tooltip for coalesce delay
#: addon/globalPlugins/terminalAccess.py:8481
msgid ""
"Milliseconds to wait before announcing accumulated new output. Larger values"
" reduce interruptions during fast output."
msgstr ""
"Počet milisekund, které je třeba počkat před oznámením nahromaděného nového "
"výstupu. Vyšší hodnoty snižují přerušení během rychlého výstupu."

#: addon/globalPlugins/terminalAccess.py:8489
msgid "&Max lines before summarising:"
msgstr "&Maximální počet řádků před shrnutím:"

# Tooltip for max lines
#: addon/globalPlugins/terminalAccess.py:8495
msgid ""
"When more than this many lines arrive at once, speak a summary ('N new "
"lines') instead of the full text."
msgstr ""
"Pokud dorazí více než tento počet řádků najednou, namísto celého textu "
"přečtěte souhrn („N nových řádků“)."

#: addon/globalPlugins/terminalAccess.py:8503
msgid "&Strip ANSI escape codes from output"
msgstr "&Odstranit ANSI escape kódy z výstupu"

# Tooltip for strip ANSI
#: addon/globalPlugins/terminalAccess.py:8507
msgid "Remove ANSI colour and formatting codes before speaking new output."
msgstr ""
"Před vyslovením nového výstupu odstraňte kódy barev a formátování ANSI."

#: addon/globalPlugins/terminalAccess.py:8514
msgid "Advanced"
msgstr "Pokročilé"

#: addon/globalPlugins/terminalAccess.py:8522
msgid "Condense &repeated symbols"
msgstr "Zhušťování a opakování symbolů"

# Tooltip for repeated symbols
#: addon/globalPlugins/terminalAccess.py:8526
msgid "Condense runs of repeated symbols (e.g., '====' becomes '4 equals')"
msgstr ""
"Zhušťujte řady opakujících se symbolů (např. „====“ se změní na „4 rovná "
"se“)."

#: addon/globalPlugins/terminalAccess.py:8533
msgid "Repeated symbols to condense:"
msgstr "Opakované symboly pro zhuštění:"

# Tooltip for repeated symbols values
#: addon/globalPlugins/terminalAccess.py:8538
msgid ""
"Characters that will be condensed when repeated. Example: -_=! (max 50 "
"characters)"
msgstr "Znaky, které se při opakování zkrátí. Příklad: -_=! (max. 50 znaků)"

#: addon/globalPlugins/terminalAccess.py:8546
