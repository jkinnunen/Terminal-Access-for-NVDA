#, python-brace-format
msgid "Selection too wide: {cols} columns exceeds maximum of {max}"
msgstr "Výběr je příliš široký: sloupce {cols} překračují maximum {max}"

#: addon/globalPlugins/terminalAccess.py:3050
msgid "Initializing..."
