msgstr "Opóźnienie kursora (w milisekundach):"

# Tooltip for cursor delay
#: addon/globalPlugins/terminalAccess.py:8358
msgid ""
"Delay before announcing cursor position (0-1000ms). Higher values reduce "
"announcement frequency."
msgstr ""
"Opóźnienie przed ogłoszeniem pozycji kursora (0–1000 ms). Wyższe wartości "
"zmniejszają częstotliwość ogłaszania."

#: addon/globalPlugins/terminalAccess.py:8366
msgid "Feedback"
msgstr "Informacje zwrotne"

#: addon/globalPlugins/terminalAccess.py:8374
msgid "Enable &key echo"
msgstr "Włącz echo klucza"

# Tooltip for key echo
#: addon/globalPlugins/terminalAccess.py:8378
msgid "Announce characters as you type in the terminal"
msgstr "Ogłaszaj znaki podczas wpisywania w terminalu"

#: addon/globalPlugins/terminalAccess.py:8385
msgid "Pause at &newlines"
msgstr "Wstrzymaj się przy znakach &newlines"

# Tooltip for line pause
#: addon/globalPlugins/terminalAccess.py:8389
msgid "Brief pause when speaking line content to improve clarity"
msgstr "Krótka pauza podczas wypowiadania treści, aby poprawić zrozumiałość"

