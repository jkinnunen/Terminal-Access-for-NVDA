# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8337
msgid "Window"
msgstr "Okno"

# Tooltip for cursor tracking mode
#: addon/globalPlugins/terminalAccess.py:8342
msgid ""
"Standard: announce line/column changes, Highlight: announce highlighted "
"text, Window: only announce within defined window"
msgstr ""
"Standard: ogłaszaj zmiany wierszy/kolumn, Podświetlenie: ogłaszaj "
"podświetlony tekst, Okno: ogłaszaj tylko w określonym oknie"

