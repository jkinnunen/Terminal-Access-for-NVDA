msgid "Cursor tracking &mode:"
msgstr "Śledzenie kursora i tryb:"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8331
msgid "Off"
msgstr "Wyłącz"

# Cursor tracking mode option
#: addon/globalPlugins/terminalAccess.py:8333
