msgstr "نسخ التحديد المستطيل بين العلامات"

#: addon/globalPlugins/terminalAccess.py:7575
msgid "Unable to determine position"
msgstr "تعذر تحديد الموقع"

#: addon/globalPlugins/terminalAccess.py:7597
